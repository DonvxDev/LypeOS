<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Lype.Glass" parent="@android:style/Theme.DeviceDefault.Light">
        <item name="android:windowBackground">@color/lype_surface_glass</item>
        <item name="android:colorPrimary">@color/lype_primary</item>
        <item name="android:colorAccent">@color/lype_secondary</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
    </style>
    <style name="Theme.Lype.Glass.Dark" parent="@android:style/Theme.DeviceDefault">
        <item name="android:windowBackground">@color/lype_surface_glass_dark</item>
        <item name="android:colorPrimary">@color/lype_primary</item>
        <item name="android:colorAccent">@color/lype_secondary</item>
    </style>
</resources>
