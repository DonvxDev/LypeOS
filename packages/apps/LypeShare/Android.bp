android_app {
    name: "LypeShare",
    srcs: ["src/**/*.kt"],
    resource_dirs: ["res"],
    manifest: "AndroidManifest.xml",
    platform_apis: true,
    certificate: "platform",
    privileged: true,
    system_ext_specific: true,
    static_libs: [
        "LypeDesignLib",
        "androidx.activity_activity-compose",
        "androidx.compose.material3_material3",
    ],
}
